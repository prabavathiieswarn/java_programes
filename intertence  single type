class Employee {
    int salary = 20000;
}

class Manager extends Employee {
    int bonus = 5000;
    void totalSalary() {
        System.out.println("Total salary: " + (salary + bonus));
    }
}

class Main {
    public static void main(String[] args) {
        Manager m = new Manager();
        m.totalSalary();
    }
}
