  abstract class Flower{
         abstract void smell ();
         abstract void  colour();
         
     }
     class Rose extends Flower {
         void smell(){
             System.out.println(" good smelling");
         }
         void  colour (){
             System.out.println(" blue");     
         }

}
public class Main
{
	public static void main(String[] args) {
	    Rose  r  =new Rose ();
    	
    	r.colour();
	   
	
	}
}
